{
  "manifest_version": 3,
  "name": "MemPilot",
  "version": "1.0.0",
  "description": "Reclaim Chrome memory: hibernate idle tabs, block trackers before load, free GPU VRAM, and manage it all from one modern popup.",
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "tabs",
    "storage",
    "declarativeNetRequest",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
